# URL of the FastAPI backend. Local dev default shown; set to your Render
# URL in production (e.g. https://soil-health-monitoring-api.onrender.com).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Used to build absolute URLs for metadata, sitemap.xml, and robots.txt.
# Set to your real Vercel domain once deployed.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
